# Azure OpenAI Configuration (Preferred)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_INTENT=intent-classifier
AZURE_OPENAI_DEPLOYMENT_NBA=nba-recommender
AZURE_OPENAI_DEPLOYMENT_FRAUD=fraud-analyzer

# Use Azure OpenAI (set to false to use OpenAI API instead)
USE_AZURE=true

# OpenAI API Configuration (Fallback)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Optional: Model Configuration Overrides
# MODEL_INTENT=gpt-4o
# MODEL_NBA=gpt-4o
# MODEL_FRAUD=gpt-4o
# TEMPERATURE_INTENT=0.3
# TEMPERATURE_NBA=0.7
# TEMPERATURE_FRAUD=0.2

# Optional: Demo Configuration
# MAX_TOKENS=1000
# TIMEOUT_SECONDS=30
